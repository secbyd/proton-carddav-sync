# proton-carddav-sync configuration
#
# You normally do NOT write this file by hand: running `proton-carddav-sync init`
# with no config present prompts for every setting below and writes it for you.
# Copy this example to ~/.config/proton-carddav-sync/config.yaml only if you
# prefer to edit it manually.
#
# No passwords or secrets live here. `init` logs in to Proton (prompting for a
# TOTP code if 2FA is enabled), then stores an encrypted, long-lasting Proton
# session and the CardDAV password in the SQLite database. The encryption key
# comes from the PCS_ENCRYPTION_KEY environment variable, which both `init` and
# the daemon must share.

proton:
  # Proton Mail username (email address).
  username: "user@proton.me"
  # x-pm-appversion sent to the Proton API. "Other" is the identifier Proton
  # accepts for unofficial clients (same as hydroxide). Override at runtime with
  # the PCS_PROTON_APP_VERSION environment variable — e.g. set it to the exact
  # x-pm-appversion your browser sends on mail.proton.me if you hit CAPTCHA.
  app_version: "Other"

carddav:
  # Full CardDAV collection URL,
  # e.g. https://nextcloud.example.com/remote.php/dav/addressbooks/users/alice/contacts/
  url: "https://dav.example.com/addressbooks/user/contacts/"
  username: "alice"

sync:
  # Direction: both | proton-to-carddav | carddav-to-proton
  direction: "both"
  # Conflict policy when the same field changed on both sides (direction: both):
  # prefer-newer (by REV) | prefer-proton | prefer-carddav
  conflict: "prefer-newer"
  # How often to sync in daemon mode, in seconds.
  interval_seconds: 900

database:
  # Path to the SQLite database file; ~ is expanded.
  path: "~/.local/share/proton-carddav-sync/sync.db"

log:
  # Level: debug | info | warn | error
  level: "info"
  # Format: text | json
  format: "text"
