# proton-carddav-sync configuration
# Copy to ~/.config/proton-carddav-sync/config.yaml and edit.
#
# Passwords are NOT stored here. Run `proton-carddav-sync init` once: it prompts
# for the Proton and CardDAV passwords and stores them encrypted in the SQLite
# database. The encryption key comes from the PCS_ENCRYPTION_KEY environment
# variable, which both `init` and the daemon must share.

proton:
  # Proton Mail username (email address).
  username: "user@proton.me"

carddav:
  # Full CardDAV collection URL,
  # e.g. https://nextcloud.example.com/remote.php/dav/addressbooks/users/alice/contacts/
  url: "https://dav.example.com/addressbooks/user/contacts/"
  username: "alice"

sync:
  # Direction: both | proton-to-carddav | carddav-to-proton
  direction: "both"
  # How often to sync in daemon mode, in seconds.
  interval_seconds: 900

database:
  # Path to the SQLite database file; ~ is expanded.
  path: "~/.local/share/proton-carddav-sync/sync.db"

log:
  # Level: debug | info | warn | error
  level: "info"
  # Format: text | json
  format: "text"
